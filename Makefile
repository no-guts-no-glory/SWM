# ---------------------------------------------------------------------------
# --  filename: Makefile
# --   purpose: build and test swm
# --   created: 10.05.2025
# --    author: fkish@1slash1.com
# -- tab width: 2
# ---------------------------------------------------------------------------
TRG=swm
LLT_OBJS=utils.c llist.c
SWM_OBJS=llist.o swm.o utils.o

# ---------------------------------------------------------------------------
CC=tcc
BIN=$(HOME)/bin
CFLAGS=-Wall           \
	-DWM_SHOW_KEYSx      \
  -DWM_SHOW_EVENTSx    \
	-DWM_USE_PROPERTIESx \
	-DWM_SHOW_PROPERTIESx

# ---------------------------------------------------------------------------
build: $(TRG)

# ---------------------------------------------------------------------------
$(TRG): $(SWM_OBJS)
	$(CC) $(CFLAGS) $(SWM_OBJS) -o swm -lX11

# ---------------------------------------------------------------------------
llist.o: llist.c llist.h

swm.o: swm.c swm.h config.h

utils.o: utils.c

# ---------------------------------------------------------------------------
ltest: $(LLT_OBJS)
	$(CC) $(CFLAGS) -DLTEST $(LLT_OBJS) -o $@

# ---------------------------------------------------------------------------
install: $(TRG)
	cp $(TRG) $(BIN)/

# ---------------------------------------------------------------------------
uninstall: clean
	rm -f $(BIN)/$(TRG)

# ---------------------------------------------------------------------------
clean:
	rm -f $(TRG) ltest *.swm *.o

